<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Register</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- TOP BAR -->
<div style="background: linear-gradient(90deg, #5b5ce6, #3b82f6);"
class="text-white text-center py-3 text-lg font-semibold">
    User Register
</div>

<div class="flex items-center justify-center min-h-[90vh]">

<form action="/user/register" method="POST"
class="bg-white text-gray-500 max-w-[340px] w-full mx-4 p-6 py-8 text-sm rounded-xl shadow-md">

    <h2 class="text-2xl font-bold mb-6 text-center text-gray-800">
        Create Account
    </h2>

    <input class="w-full border rounded px-3 py-2 mb-3"
    type="text" name="name" placeholder="Full Name" required>

    <input class="w-full border rounded px-3 py-2 mb-3"
    type="email" name="email" placeholder="Email" required>

    <input class="w-full border rounded px-3 py-2 mb-4"
    type="password" name="password" placeholder="Password" required>

    <button type="submit"
    style="background: linear-gradient(90deg, #5b5ce6, #3b82f6);"
    class="w-full py-2.5 rounded text-white font-medium">
        Register
    </button>

    <p class="text-center mt-4">
        Already have an account?
        <a href="/user/login" class="text-blue-600 underline">Login</a>
    </p>

</form>

</div>
</body>
</html>