<!DOCTYPE html>
<html>
<head>
    <title>All Services</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #c7d3db;
        }

        .circle-img {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            object-fit: cover;
        }

        .bottom-buttons {
            margin-top: 20px;
        }
        .table-dark-custom {
    background-color: black;
    color: white;
}

.table-dark-custom th {
    background-color: black !important;
    color: white;
}

.table-dark-custom td {
    background-color: black !important;
    color: white;
}

.table-dark-custom tr {
    background-color: black !important;
}
    </style>
</head>

<body>

<div class="container mt-4">

    <h2>All Services</h2>

    <!-- 🔥 BUTTONS (YOUR REQUIREMENT) -->
    <div class="bottom-buttons mb-3">
        <a href="/admin/service/add" class="btn btn-dark btn-sm">+ Add New</a>
        <a href="/admin/dashboard" class="btn btn-dark btn-sm">← Dashboard</a>
    </div>

    <table class="table mt-3 table-dark-custom">
        <thead>
            <tr>
                <th>Title</th>
                <th>Price</th>
                <th>Image</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            <% services.forEach(service => { %>
                <tr>
                    <td><%= service.title %></td>
                    <td>₹ <%= service.price %></td>
                    <td>
                        <img src="/uploads/<%= service.image %>" class="circle-img">
                    </td>
                    <td>
                        <a href="/admin/service/edit/<%= service._id %>" class="btn btn-primary btn-sm">Edit</a>
                        <a href="/admin/service/delete/<%= service._id %>" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>

    </table>

</div>

</body>
</html>