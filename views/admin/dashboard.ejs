<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">

    <style>
        body {
            background: #eaf6fb;
        }

        .topbar {
            background: #0d1b2a;
            color: white;
            padding: 15px;
        }

        .card-custom {
            background: linear-gradient(135deg, #0d3b66, #1e6091);
            color: white;
            border-radius: 10px;
        }
        .service-card {
    background: #000000;   /* 🔥 PURE BLACK */
    color: white;
    border-radius: 12px;
}

.btn-blue {
    background: #0d6efd;   /* Bootstrap blue */
    color: white;
    padding: 6px 16px;
    border-radius: 6px;
    display: inline-block;  /* IMPORTANT */
    text-decoration: none;
    font-size: 14px;
}

.btn-blue:hover {
    background: #0b5ed7;
    color: white;
}
    </style>
</head>
<body>

<div class="topbar d-flex justify-content-between align-items-center">
    <h4>Welcome: <%= user.fullname %></h4>
    <a href="/admin/logout" class="btn btn-light btn-sm">Logout</a>
</div>

<div class="container mt-5">
    <div class="row">

        <div class="col-md-6">
            <div class="service-card p-4 shadow">
                <h5 class="text-white">Services</h5>

                <a href="/admin/service/add" class="btn-blue mt-3">
                    Add Service
                </a>
            </div>
        </div>

        <div class="col-md-6">
            <div class="service-card p-4 shadow">
                <h5 class="text-white">Services</h5>

                <a href="/admin/services" class="btn-blue mt-3">
                    View Services
                </a>
            </div>
        </div>

    </div>
</div>

</body>
</html>