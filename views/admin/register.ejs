<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <title>Register</title>
</head>
<body>

<div class="container mt-5">
    <h2>Register</h2>

    <form method="POST" action="/admin/register">
        <input type="text" name="fullname" placeholder="Full Name" class="form-control my-2" required>
        <input type="email" name="email" placeholder="Email" class="form-control my-2" required>
        <input type="password" name="password" placeholder="Password" class="form-control my-2" required>

        <button class="btn btn-dark">Register</button>
    </form>

    <p class="mt-3">
        Already have account? <a href="/admin/login">Login</a>
    </p>
</div>

</body>
</html>